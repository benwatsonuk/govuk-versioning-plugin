{% if params.versions and params.versions.length %}

<ul class="govuk-list govuk-list--bullet">
  {% for version in params.versions | reverse %}
  {% set versionTitle = version.version %}
  {% if version.name %}
      {% set versionTitle = version.name + " (<span style='text-transform: uppercase'>" + version.version + "</span>)" %}
  {% endif %}
    <li>
      <a href=""><strong>{{ versionTitle | safe }}</strong></a>

      {% if version.notes %}
        <br>
        <span class="govuk-hint">
          {{ version.notes }}
        </span>
      {% endif %}
    </li>
  {% endfor %}
</ul>

{% else %}

<p>No versions found.</p>

{% endif %}