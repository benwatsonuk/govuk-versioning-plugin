{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["mode"],
    "properties": {
        "mode": {
            "type": "string",
            "enum": ["versions", "versionToCreate", "config"]
        }
    },
    "allOf": [
        {
            "if": {
                "properties": { "mode": { "const": "versions" } }
            },
            "then": { "$ref": "#/definitions/versions" }
        },
        {
            "if": {
                "properties": { "mode": { "const": "versionToCreate" } }
            },
            "then": { "$ref": "#/definitions/versionToCreate" }
        },
        {
            "if": {
                "properties": { "mode": { "const": "config" } }
            },
            "then": { "$ref": "#/definitions/config" }
        }
    ],
    "definitions": {
        "versions": {
            "type": "object",
            "required": ["mode", "versions"],
            "properties": {
                "mode": { "const": "versions" },
                "versions": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["iteration", "version", "createdOn"],
                        "properties": {
                            "iteration": { "type": "integer" },
                            "version": { "type": "string" },
                            "createdOn": { "type": "string", "format": "date-time" },
                            "phase": { "type": "string" },
                            "notes": { "type": ["string", "null"] },
                            "additionalProperties": false
                        }
                    }
                }
            },
            "additionalProperties": false
        },
        "versionToCreate": {
            "type": "object",
            "required": ["mode", "versionToCreate"],
            "properties": {
                "mode": { "const": "versionToCreate" },
                "versionToCreate": {
                    "type": "object",
                    "required": ["version", "phase", "config"],
                    "properties": {
                        "version": { "type": "string" },
                        "phase": { "type": "string" },
                        "config": { "type": "object" }
                    }
                }
            },
            "additionalProperties": false
        },
        "config": {
            "type": "object",
            "required": ["mode", "config"],
            "properties": {
                "mode": { "const": "config" },
                "config": {
                    "type": "object",
                    "required": ["itemsToClone"],
                    "properties": {
                        "itemsToClone": {
                            "type": "array",
                            "items": { "type": "string" }
                        }
                    }
                },
                "additionalProperties": false
            }
        }
    }
}
