{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["mode"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["versions", "versionToCreate", "config"]
    }
  },
   "allOf": [
    {
      "if": {
        "properties": { "mode": { "const": "versions" } }
      },
      "then": { "$ref": "#/definitions/versions" }
    },
    {
      "if": {
        "properties": { "mode": { "const": "versionToCreate" } }
      },
      "then": { "$ref": "#/definitions/versionToCreate" }
    },
    {
      "if": {
        "properties": { "mode": { "const": "config" } }
      },
      "then": { "$ref": "#/definitions/config" }
    }
  ],
  "definitions": {
    "versions": {
      "type": "object",
      "required": ["mode", "versions"],
      "properties": {
        "mode": { "const": "versions" },
        "versions": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["iteration", "version", "createdOn"],
          "properties": {
            "iteration": { "type": "integer" },
            "version": { "type": "string" },
            "createdOn": { "type": "string" },
            "phase": { "type": "string" },
            "notes": { "type": ["string", "null"] },
            "additionalProperties": false
            }
          }
        }
      },
      "additionalProperties": false
    },
    "versionToCreate": {
      "type": "object",
      "required": ["mode", "versionToCreate"],
      "properties": {
        "mode": { "const": "versionToCreate" },
        "versionToCreate": {
          "type": "object",
          "required": ["newVersion", "newPhase", "oldVersion", "oldPhase", "iteration"],
          "properties": {
            "newVersion": { "type": "string" },
            "newPhase": { "type": "string" },
            "newVersionName": { "type": "string" },
            "iteration": { "type": "integer" },
            "notes": { "type": ["string", "null"] },
            "oldVersion": { "type": "string" },
            "oldPhase": { "type": "string" },
            "itemsToClone": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "path"],
                "properties": {
                  "type": { "type": "string", "enum": ["file", "directory"] },
                  "path": { "type": "string" }
                }
              }
            },
            "itemsToUpdate": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["path", "find", "add"],
                "properties": {
                  "path": { "type": "string" },
                  "find": { "type": "string" },
                  "add": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "config": {
      "type": "object",
      "required": ["mode", "config"],
      "properties": {
        "mode": { "const": "config" },
        "config": { 
          "type": "object",
          "required": ["itemsToClone"],
          "properties": {
            "itemsToClone": {
              "type": "array",
              "items": { "type": "object" },
              "properties": {
                "type": {"type": "string", "enum": ["file", "directory"]},
                "path": {"type": "string"}
              }
            }
          }
        },
      "additionalProperties": false
      }
    }
  }
}
